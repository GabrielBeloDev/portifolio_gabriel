{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "velite && concurrently -k \"velite --watch\" \"next dev\"",
    "build": "velite && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "velite && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@gabriel/db": "workspace:*",
    "@gabriel/ui": "workspace:*",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@gabriel/config": "workspace:*",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.7.0",
    "mdast-util-mdx-jsx": "^3.2.0",
    "postcss": "^8.5.19",
    "rehype-pretty-code": "^0.14.4",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "unist-util-visit": "^5.1.0",
    "velite": "^0.4.0",
    "vitest": "^4.1.10"
  }
