# Required — Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Required — Better Auth session signing secret, min. 32 chars
# Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-string-of-32-plus-chars"

# Optional — public base URL of the app, used for auth callbacks
# BETTER_AUTH_URL="http://localhost:3000"

# Optional — GitHub OAuth (both required to enable "Sign in with GitHub")
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# Optional — Google OAuth (both required to enable "Sign in with Google")
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
